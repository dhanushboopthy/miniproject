# Environment variables for Docker setup
# Copy this file to .env and customize for your environment

# MongoDB Configuration (Docker uses service name 'mongodb')
MONGO_URI=mongodb://admin:admin123@mongodb:27017/anganwadi?authSource=admin

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production-12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend URL
FRONTEND_URL=http://localhost:5173

# OpenRouter API Configuration (Required for AI features)
OPENROUTER_API_KEY=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
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_PRIMARY_MODEL=anthropic/claude-3-haiku
OPENROUTER_FALLBACK_MODEL=meta-llama/llama-3-8b-instruct

# Fast2SMS Configuration (Required for SMS notifications)
FAST2SMS_API_KEY=your-fast2sms-api-key-here

# SMTP Configuration (Required for Email notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password
