# JWT Configuration
JWT_SECRET=your-super-secret-key-change-this-in-production-12345
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend URL
FRONTEND_URL=http://localhost:5173

# OpenRouter API Configuration (Required for AI features)
OPENROUTER_API_KEY=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
